{
  "name": "ceph-command-kb-vscode",
  "displayName": "Ceph Command KB for Bob",
  "description": "Integrate Ceph Command Knowledge Base with IBM watsonx Code Assistant (Bob)",
  "version": "0.1.0",
  "publisher": "ceph-cmd-kb",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:ceph-cmd-kb.verifyCommand",
    "onCommand:ceph-cmd-kb.searchCommands",
    "onCommand:ceph-cmd-kb.verifyConfig",
    "onCommand:ceph-cmd-kb.reviewScript",
    "onCommand:ceph-cmd-kb.insertCommand"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ceph-cmd-kb.verifyCommand",
        "title": "Ceph KB: Verify Command"
      },
      {
        "command": "ceph-cmd-kb.searchCommands",
        "title": "Ceph KB: Search Commands"
      },
      {
        "command": "ceph-cmd-kb.verifyConfig",
        "title": "Ceph KB: Verify Config"
      },
      {
        "command": "ceph-cmd-kb.reviewScript",
        "title": "Ceph KB: Review Script"
      },
      {
        "command": "ceph-cmd-kb.insertCommand",
        "title": "Ceph KB: Insert Command"
      }
    ],
    "keybindings": [
      {
        "command": "ceph-cmd-kb.verifyCommand",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      },
      {
        "command": "ceph-cmd-kb.searchCommands",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Ceph Command KB",
      "properties": {
        "ceph-cmd-kb.apiUrl": {
          "type": "string",
          "default": "http://localhost:9090",
          "description": "Ceph Command KB REST API URL"
        },
        "ceph-cmd-kb.autoVerify": {
          "type": "boolean",
          "default": false,
          "description": "Automatically verify Ceph commands as you type"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "eslint": "^8.41.0"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
